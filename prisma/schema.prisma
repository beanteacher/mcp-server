generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SendSmsTranAlarm {
  msgId             BigInt    @id @default(autoincrement()) @map("msg_id") @db.BigInt
  msgType           String    @map("msg_type") @db.VarChar(4)
  msgSubType        String    @map("msg_sub_type") @db.VarChar(5)
  groupId           BigInt?   @map("group_id") @db.BigInt
  userId            String?   @map("user_id") @db.VarChar(32)
  kisaCode          String?   @map("kisa_code") @db.VarChar(20)
  destaddr          String    @db.VarChar(32)
  callback          String    @db.VarChar(32)
  billCode          String?   @map("bill_code") @db.VarChar(10)
  sendMsg           String?   @map("send_msg") @db.VarChar(300)
  originMsgId       BigInt?   @map("origin_msg_id") @db.BigInt
  originMsgType     String?   @map("origin_msg_type") @db.VarChar(5)
  messageState      Int       @default(0) @map("message_state") @db.TinyInt
  retryCount        Int?      @default(0) @map("retry_count") @db.TinyInt
  createDate        DateTime  @default(now()) @map("create_date")
  updateDate        DateTime  @default(now()) @map("update_date")
  requestDate       DateTime  @default(now()) @map("request_date")
  resultDeliverDate DateTime? @map("result_deliver_date")
  resultCode        String?   @map("result_code") @db.VarChar(5)
  resultNetId       String?   @map("result_net_id") @db.VarChar(4)
  etcChar1          String?   @map("etc_char_1") @db.VarChar(100)
  etcChar2          String?   @map("etc_char_2") @db.VarChar(100)
  etcChar3          String?   @map("etc_char_3") @db.VarChar(100)
  etcChar4          String?   @map("etc_char_4") @db.VarChar(100)
  etcInt5           Int?      @map("etc_int_5")
  etcInt6           Int?      @map("etc_int_6")
  etcInt7           Int?      @map("etc_int_7")
  etcInt8           Int?      @map("etc_int_8")

  @@index([messageState, requestDate, msgType], map: "idx_fetch")
  @@map("send_sms_tran_alarm")
}
