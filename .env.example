# Prisma MariaDB 연결 문자열
# 예시: mysql://USER:PASSWORD@HOST:3306/DB_NAME
DATABASE_URL="mysql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>"

# send_sms_tran_alarm 기본값 (tool 인자로 넘기지 않을 때 사용)
MCP_TRAN_DEFAULT_CALLBACK=""
MCP_TRAN_DEFAULT_USER_ID=""
MCP_TRAN_DEFAULT_KISA_CODE=""
MCP_TRAN_DEFAULT_BILL_CODE=""
